# MCP adapter credentials — NAMES ONLY, never commit real values.
#
# Copy to an untracked .env (or export in your shell / secret manager) and
# fill in values there. Adapters resolve these at runtime through the
# credential provider layer (hub.mcp_runtime.auth); the repository must
# never contain live credentials.

MCP_CONTRACTS_API_KEY=
