{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "federation_relationship.schema.json",
  "title": "Federation Relationship",
  "description": "A directed relationship between two entities, with provenance evidence.",
  "type": "object",
  "required": [
    "relationship_id",
    "source_id",
    "source_entity_id",
    "target_entity_id",
    "relationship_type",
    "evidence_source_id",
    "confidence",
    "lineage",
    "synthetic",
    "created_at",
    "extracted_at"
  ],
  "properties": {
    "relationship_id": {"type": "string", "pattern": "^rel_[a-f0-9]{32}$"},
    "source_id": {"type": "string", "pattern": "^src_[a-f0-9]{32}$"},
    "source_entity_id": {"type": "string", "pattern": "^ent_[a-f0-9]{32}$"},
    "target_entity_id": {"type": "string", "pattern": "^ent_[a-f0-9]{32}$"},
    "relationship_type": {"type": "string"},
    "evidence_source_id": {"type": "string", "pattern": "^src_[a-f0-9]{32}$"},
    "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "lineage": {"$ref": "#/definitions/lineage"},
    "synthetic": {"type": "boolean"},
    "created_at": {"type": "string", "format": "date-time"},
    "extracted_at": {"type": "string", "format": "date-time"}
  },
  "definitions": {
    "lineage": {
      "type": "object",
      "required": ["producer_script", "producer_phase", "source_inputs"],
      "properties": {
        "producer_script": {"type": "string"},
        "producer_phase": {"type": "string"},
        "source_inputs": {"type": "array", "items": {"type": "string"}},
        "extraction_method": {"type": "string"}
      }
    }
  }
}
