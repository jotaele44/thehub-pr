{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "federation_source.schema.json",
  "title": "Federation Source",
  "description": "Provenance record describing where downstream rows came from. Federation-canonical; producers conform to this shape.",
  "type": "object",
  "required": [
    "source_id",
    "source_type",
    "source_name",
    "confidence",
    "lineage",
    "synthetic",
    "created_at",
    "extracted_at"
  ],
  "properties": {
    "source_id": {"type": "string", "pattern": "^src_[a-f0-9]{32}$"},
    "source_type": {"type": "string"},
    "source_name": {"type": "string"},
    "source_url": {"type": "string", "format": "uri"},
    "source_ref": {"type": "string", "description": "Stable semantic reference (e.g. registry source_id)."},
    "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "lineage": {"$ref": "#/definitions/lineage"},
    "synthetic": {"type": "boolean"},
    "created_at": {"type": "string", "format": "date-time"},
    "extracted_at": {"type": "string", "format": "date-time"}
  },
  "anyOf": [
    {"required": ["source_url"]},
    {"required": ["source_ref"]}
  ],
  "definitions": {
    "lineage": {
      "type": "object",
      "required": ["producer_script", "producer_phase", "source_inputs"],
      "properties": {
        "producer_script": {"type": "string"},
        "producer_phase": {"type": "string"},
        "source_inputs": {"type": "array", "items": {"type": "string"}},
        "extraction_method": {"type": "string"}
      }
    }
  }
}
