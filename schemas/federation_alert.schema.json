{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "federation_alert.schema.json",
  "title": "Federation Alert",
  "description": "A canonical operational-alert row emitted by an infrastructure-monitoring producer (e.g. aguayluz-pr). Carries a sector-classified, evidence-backed alert event with severity, lifecycle status, gap state, an optional anchor entity, and an optional WGS84 location for cross-producer correlation.",
  "type": "object",
  "required": [
    "alert_id",
    "source_id",
    "module",
    "alert_type",
    "severity",
    "status",
    "observed_at",
    "confidence",
    "lineage",
    "synthetic",
    "created_at",
    "extracted_at"
  ],
  "properties": {
    "alert_id": {"type": "string", "pattern": "^alrt_[a-f0-9]{32}$"},
    "source_id": {"type": "string", "pattern": "^src_[a-f0-9]{32}$"},
    "entity_id": {
      "type": "string",
      "pattern": "^ent_[a-f0-9]{32}$",
      "description": "Optional link to the canonical entity (e.g. utility asset) this alert is attributed to."
    },
    "module": {
      "type": "string",
      "description": "Producer alert-module classification (e.g. HYDRO_OPS, POWER_OPS, DAM_SAFETY)."
    },
    "alert_type": {
      "type": "string",
      "description": "Normalized operational event type (e.g. maintenance, outage, failure, quality, hazard, inspection)."
    },
    "severity": {"type": "integer", "minimum": 0, "maximum": 5},
    "status": {"enum": ["draft", "validated", "active", "closed", "rejected"]},
    "gap_status": {"enum": ["none", "minor", "major", "blocking"]},
    "observed_at": {"type": "string", "format": "date-time"},
    "start_at": {"type": "string", "format": "date-time"},
    "end_at": {"type": "string", "format": "date-time"},
    "location": {
      "type": "object",
      "description": "Optional WGS84 point geometry for cross-producer spatial joins.",
      "required": ["lat", "lon"],
      "properties": {
        "lat": {"type": "number", "minimum": -90.0, "maximum": 90.0},
        "lon": {"type": "number", "minimum": -180.0, "maximum": 180.0},
        "municipality": {"type": "string"}
      }
    },
    "attributes": {
      "type": "object",
      "description": "Producer-specific alert payload (asset name, municipalities, evidence tier, covert flags, etc.). No Hub-level schema constraint.",
      "additionalProperties": true
    },
    "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "lineage": {"$ref": "#/definitions/lineage"},
    "synthetic": {"type": "boolean"},
    "created_at": {"type": "string", "format": "date-time"},
    "extracted_at": {"type": "string", "format": "date-time"}
  },
  "definitions": {
    "lineage": {
      "type": "object",
      "required": ["producer_script", "producer_phase", "source_inputs"],
      "properties": {
        "producer_script": {"type": "string"},
        "producer_phase": {"type": "string"},
        "source_inputs": {"type": "array", "items": {"type": "string"}},
        "extraction_method": {"type": "string"}
      }
    }
  }
}
