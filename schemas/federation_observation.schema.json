{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "federation_observation.schema.json",
  "title": "Federation Observation",
  "description": "A canonical observation row emitted by an airspace or sensor producer (e.g. skywatcher-pr). Carries a detected event at a point in time, optionally anchored to an entity and a WGS84 location.",
  "type": "object",
  "required": [
    "observation_id",
    "source_id",
    "observation_type",
    "observed_at",
    "confidence",
    "lineage",
    "synthetic",
    "created_at",
    "extracted_at"
  ],
  "properties": {
    "observation_id": {"type": "string", "pattern": "^obs_[a-f0-9]{32}$"},
    "source_id": {"type": "string", "pattern": "^src_[a-f0-9]{32}$"},
    "entity_id": {
      "type": "string",
      "pattern": "^ent_[a-f0-9]{32}$",
      "description": "Optional link to a canonical entity this observation is attributed to."
    },
    "observation_type": {
      "type": "string",
      "description": "Producer-defined observation category (e.g. aircraft_transit, vessel_position, sensor_reading)."
    },
    "observed_at": {"type": "string", "format": "date-time"},
    "location": {
      "type": "object",
      "description": "Optional WGS84 point geometry for cross-producer spatial joins.",
      "required": ["lat", "lon"],
      "properties": {
        "lat": {"type": "number", "minimum": -90.0, "maximum": 90.0},
        "lon": {"type": "number", "minimum": -180.0, "maximum": 180.0},
        "altitude_ft": {"type": "number"},
        "municipality": {"type": "string"}
      }
    },
    "attributes": {
      "type": "object",
      "description": "Producer-specific observation payload (e.g. callsign, speed, heading). No Hub-level schema constraint.",
      "additionalProperties": true
    },
    "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "lineage": {"$ref": "#/definitions/lineage"},
    "synthetic": {"type": "boolean"},
    "created_at": {"type": "string", "format": "date-time"},
    "extracted_at": {"type": "string", "format": "date-time"}
  },
  "definitions": {
    "lineage": {
      "type": "object",
      "required": ["producer_script", "producer_phase", "source_inputs"],
      "properties": {
        "producer_script": {"type": "string"},
        "producer_phase": {"type": "string"},
        "source_inputs": {"type": "array", "items": {"type": "string"}},
        "extraction_method": {"type": "string"}
      }
    }
  }
}
