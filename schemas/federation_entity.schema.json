{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "federation_entity.schema.json",
  "title": "Federation Entity",
  "description": "A canonical entity row (agency, recipient, vendor, person, asset, etc.).",
  "type": "object",
  "required": [
    "entity_id",
    "source_id",
    "name",
    "normalized_name",
    "entity_type",
    "jurisdiction",
    "confidence",
    "lineage",
    "synthetic",
    "created_at",
    "extracted_at"
  ],
  "properties": {
    "entity_id": {"type": "string", "pattern": "^ent_[a-f0-9]{32}$"},
    "source_id": {"type": "string", "pattern": "^src_[a-f0-9]{32}$"},
    "name": {"type": "string"},
    "normalized_name": {"type": "string"},
    "entity_type": {"type": "string"},
    "jurisdiction": {"type": "string"},
    "external_ids": {
      "type": "object",
      "description": "Optional external identifiers for cross-repo entity matching by downstream consumers.",
      "properties": {
        "uei": {"type": "string"},
        "parent_uei": {"type": "string"}
      }
    },
    "location": {
      "type": "object",
      "description": "Optional WGS84 point geometry for cross-producer spatial joins (e.g. spiderweb correlate_spatial, PRIIS scoring). Present only when the producer carries real coordinates upstream.",
      "required": ["lat", "lon"],
      "properties": {
        "lat": {"type": "number", "minimum": -90.0, "maximum": 90.0},
        "lon": {"type": "number", "minimum": -180.0, "maximum": 180.0},
        "municipality": {"type": "string"}
      }
    },
    "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "lineage": {"$ref": "#/definitions/lineage"},
    "synthetic": {"type": "boolean"},
    "created_at": {"type": "string", "format": "date-time"},
    "extracted_at": {"type": "string", "format": "date-time"}
  },
  "definitions": {
    "lineage": {
      "type": "object",
      "required": ["producer_script", "producer_phase", "source_inputs"],
      "properties": {
        "producer_script": {"type": "string"},
        "producer_phase": {"type": "string"},
        "source_inputs": {"type": "array", "items": {"type": "string"}},
        "extraction_method": {"type": "string"}
      }
    }
  }
}
