{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "1.0.1",
  "typography": {
    "fontFamily": "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif",
    "sizes": {"xs":"0.75rem","sm":"0.875rem","md":"1rem","lg":"1.125rem","xl":"1.25rem","2xl":"1.5rem","3xl":"1.875rem"},
    "weights": {"regular":400,"medium":500,"semibold":600,"bold":700}
  },
  "spacing": {"0":"0","1":"0.25rem","2":"0.5rem","3":"0.75rem","4":"1rem","5":"1.25rem","6":"1.5rem","8":"2rem","10":"2.5rem","12":"3rem"},
  "radius": {"sm":"0.375rem","md":"0.5rem","lg":"0.75rem","xl":"1rem","pill":"9999px"},
  "elevation": {"1":"0 1px 2px rgba(0,0,0,.18)","2":"0 4px 12px rgba(0,0,0,.22)","3":"0 12px 32px rgba(0,0,0,.28)"},
  "motion": {"fast":"120ms","normal":"180ms","slow":"260ms","easing":"cubic-bezier(.2,.8,.2,1)"},
  "semantic": {
    "status": {
      "operational":{"foreground":"#166534","background":"#dcfce7","signal":"#22c55e"},
      "degraded":{"foreground":"#854d0e","background":"#fef9c3","signal":"#eab308"},
      "critical":{"foreground":"#991b1b","background":"#fee2e2","signal":"#ef4444"},
      "offline":{"foreground":"#334155","background":"#e2e8f0","signal":"#64748b"},
      "information":{"foreground":"#1e40af","background":"#dbeafe","signal":"#3b82f6"},
      "analysis":{"foreground":"#6b21a8","background":"#f3e8ff","signal":"#8b5cf6"}
    },
    "light": {"background":"#f8fafc","surface":"#ffffff","surfaceSecondary":"#f1f5f9","textPrimary":"#0f172a","textSecondary":"#475569","border":"#cbd5e1"},
    "dark": {"background":"#070b14","surface":"#0f172a","surfaceSecondary":"#172033","textPrimary":"#f8fafc","textSecondary":"#94a3b8","border":"#334155"}
  },
  "repoAccents": {
    "thehub-pr":"#2563eb",
    "spiderweb-pr":"#0d9488",
    "skywatcher-pr":"#0891b2",
    "moneysweep-pr":"#16a34a",
    "centinelas-pr":"#ea580c",
    "aguayluz-pr":"#15803d",
    "ovnis-pr":"#7c3aed"
  },
  "iconography": {"library":"lucide-react","defaultSize":18,"strokeWidth":1.75}
}
